# NeuroLearn AI — Environment Variables
# Copy this file to .env and fill in your values.

# Google Gemini API Key — get one FREE at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=neurolearn-super-secret-key-change-in-production
JWT_EXPIRE_MINUTES=10080

# App settings
APP_NAME=NeuroLearn AI
DEBUG=true
